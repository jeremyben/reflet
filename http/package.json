{
	"name": "@reflet/http",
	"version": "1.0.0",
	"author": "Jeremy Bensimon",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jeremyben/reflet.git",
		"directory": "http"
	},
	"homepage": "https://github.com/jeremyben/reflet/tree/master/http#readme",
	"description": "Low-level TypeScript HTTP-related modules",
	"keywords": [
		"http",
		"status",
		"error",
		"error-handling",
		"headers",
		"typescript"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=10"
	},
	"engineStrict": true,
	"devDependencies": {
		"@types/express": "^4.17.17",
		"express": "^4.18.2"
	},
	"scripts": {
		"build": "ts-node -T ../build.ts",
		"test": "jest --config ../jest.config.js",
		"test:watch": "pnpm test --watch --verbose false",
		"test:file": "pnpm test --testPathPattern",
		"release": "release-it --config ../.release-it.js --git.requireBranch=master",
		"release:next": "release-it --config ../.release-it.js --preRelease=next"
	}
}
